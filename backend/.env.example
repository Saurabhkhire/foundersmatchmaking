DATABASE_PROVIDER=neon
DATABASE_URL=postgresql://<user>:<password>@<neon-host>/<db>?sslmode=require
SQLITE_URL=file:./dev.db
JWT_SECRET="replace-with-strong-secret"
OPENAI_API_KEY=""
# Matching speed: parallel embedding + explanation LLM calls (defaults 10 / 8). Set MATCH_SKIP_AI_EXPLANATIONS=true to skip per-match OpenAI (fastest).
MATCH_CONCURRENCY_EMBEDDINGS="10"
MATCH_CONCURRENCY_EXPLANATIONS="8"
MATCH_SKIP_AI_EXPLANATIONS=""
FRONTEND_URL=http://localhost:3000
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
SMTP_SEND_CONCURRENCY="6"
ADMIN_EMAIL=admin@foundermatch.local
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeThisNow123!
ADMIN_COMPANY_NAME="Founder Match Admin"
